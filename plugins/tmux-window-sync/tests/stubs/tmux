#!/usr/bin/env bash
# Test stub for tmux: log the invocation, answer queries from env vars.
printf '%s\n' "$*" >> "${TMUX_STUB_LOG:-/dev/null}"
case "${1:-}" in
  display-message)
    # The format string is the last argument; answer id vs name distinctly.
    last="${!#}"
    case "$last" in
      *window_id*)   printf '%s\n' "${STUB_WINDOW_ID:-@1}" ;;
      *window_name*) printf '%s\n' "${STUB_WINDOW_NAME:-orig-window}" ;;
      *)             printf '%s\n' "${STUB_WINDOW_NAME:-orig-window}" ;;
    esac
    ;;
  show-window-options)
    last="${!#}"
    case "$last" in
      *window-status-current-style*) printf '%s\n' "${STUB_WINDOW_STATUS_CURRENT_STYLE:-}" ;;
      *window-status-style*)         printf '%s\n' "${STUB_WINDOW_STATUS_STYLE:-}" ;;
      *)                             printf '%s\n' "${STUB_AUTO_RENAME:-on}" ;;
    esac
    ;;
esac
exit 0
